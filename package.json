{
  "name": "tasks-management-system",
  "private": true,
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "dev:backend": "pnpm --filter backend dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "lint": "biome check .",
